{
  "name": "skuoty",
  "version": "0.3.4",
  "description": "AI-powered text processor triggered by double Ctrl+C",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "electron": "electron .",
    "rebuild": "electron-rebuild",
    "start": "npm run build && npm run electron",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && scripts\\dist-linux.bat",
    "dist:linux:ci": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit"
  },
  "keywords": [
    "electron",
    "ai",
    "clipboard",
    "translation"
  ],
  "author": {"name": "Leonardo Ciaccio", "email": "leonardo@skuoty.app"},
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "electron-store": "^8.2.0",
    "uiohook-napi": "^1.5.4",
    "vue": "^3.5.0"
  },
  "build": {
    "appId": "com.skuoty.app",
    "productName": "Skuoty",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/skuoty.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/skuoty.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/skuoty.png"
    }
  }
}